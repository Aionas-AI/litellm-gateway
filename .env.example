# ── Public hostname for the gateway ──────────────────────────────────────
# Caddy uses this to auto-provision a Let's Encrypt TLS certificate.
#
# NO DOMAIN? Leave this blank. bootstrap.sh will auto-derive a magic-DNS
# hostname (<public-ip>.sslip.io) that resolves to this box, so you still get
# a real Let's Encrypt cert with no domain purchase and no DNS provider.
#
# Using your own domain? Set it here and point an A record at the box's IP:
#   DOMAIN=llm.example.com
DOMAIN=

# ── LiteLLM master key ───────────────────────────────────────────────────
# The single bearer token every client must send. Generate a strong value:
#   python3 -c "import secrets; print('sk-' + secrets.token_urlsafe(32))"
LITELLM_MASTER_KEY=sk-change-me

# ── AWS region for Bedrock ───────────────────────────────────────────────
# Bedrock credentials come from the EC2 instance IAM role — no keys here.
AWS_REGION=eu-north-1

# ── Postgres password ────────────────────────────────────────────────────
# Backs the Admin UI, virtual keys, budgets, and spend history. Generate one:
#   python3 -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=change-me-strong

# ── Web chat UI key ──────────────────────────────────────────────────────
# Virtual key injected server-side by Caddy for the chat UI at chat.<DOMAIN>,
# so the browser never sees a key. Mint one scoped to the UI's models.
WEBCHAT_API_KEY=sk-your-webchat-virtual-key

# ── Key-manager admin token ──────────────────────────────────────────────
# Bearer token for the tenant key-management service (localhost:9100 on the
# box). Caddy injects it server-side for the keys.<DOMAIN> browser UI, so it
# never reaches the browser. Generate a strong value:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
KEY_MANAGER_ADMIN_TOKEN=change-me-strong

# ── Key admin UI login (keys.<DOMAIN>) ───────────────────────────────────
# Browser login for the tenant-key admin page. The hash is bcrypt; make it:
#   docker compose exec caddy caddy hash-password --plaintext 'your-password'
# NOTE: if the hash contains `$`, double every `$` as `$$` in this file so
# docker compose does not treat them as variable references.
KEYADMIN_USER=admin
KEYADMIN_PASSWORD_HASH=

# ── LiteLLM Enterprise license (optional) ────────────────────────────────
# Enables enterprise features. Leave blank for the free/OSS proxy.
# Never commit the real value — pull it from AWS Secrets Manager:
#   aws secretsmanager get-secret-value --region eu-north-1 \
#     --secret-id litellm-gateway/LITELLM_LICENSE --query SecretString --output text
LITELLM_LICENSE=
