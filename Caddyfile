# API gateway (OpenAI-compatible LiteLLM proxy)
{$DOMAIN} {
	reverse_proxy litellm:4000
}

# Tenant key admin UI. The static page is public (no secrets in it); every
# /api/* call requires either the key-manager's session cookie (issued by the
# login form via /api/auth/login) or the admin bearer token. Caddy is a plain
# TLS proxy here — credentials never live at the edge.
keys.{$DOMAIN} {
	handle_path /api/* {
		reverse_proxy key-manager:9100
	}

	handle {
		root * /srv/keyadmin
		file_server
	}
}

# Small web chat UI. Static page + a key-injecting proxy so the browser
# never sees the API key. /api/chat is rewritten to the LiteLLM endpoint
# with the Authorization header added server-side by Caddy.
chat.{$DOMAIN} {
	root * /srv/webchat

	@api path /api/chat
	handle @api {
		rewrite * /v1/chat/completions
		reverse_proxy litellm:4000 {
			header_up Authorization "Bearer {$WEBCHAT_API_KEY}"
		}
	}

	handle {
		file_server
	}
}
