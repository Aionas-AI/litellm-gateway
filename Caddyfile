# API gateway (OpenAI-compatible LiteLLM proxy)
{$DOMAIN} {
	reverse_proxy litellm:4000
}

# Tenant key admin UI. Locked behind HTTPS + basic-auth login; Caddy then
# swaps the browser's Basic credentials for the key-manager bearer token, so
# the admin token never reaches the browser. The key-manager itself stays
# unexposed (localhost + docker network only) as a second auth layer.
keys.{$DOMAIN} {
	basic_auth {
		{$KEYADMIN_USER} {$KEYADMIN_PASSWORD_HASH}
	}

	handle_path /api/* {
		reverse_proxy key-manager:9100 {
			header_up Authorization "Bearer {$KEY_MANAGER_ADMIN_TOKEN}"
		}
	}

	handle {
		root * /srv/keyadmin
		file_server
	}
}

# Small web chat UI. Static page + a key-injecting proxy so the browser
# never sees the API key. /api/chat is rewritten to the LiteLLM endpoint
# with the Authorization header added server-side by Caddy.
chat.{$DOMAIN} {
	root * /srv/webchat

	@api path /api/chat
	handle @api {
		rewrite * /v1/chat/completions
		reverse_proxy litellm:4000 {
			header_up Authorization "Bearer {$WEBCHAT_API_KEY}"
		}
	}

	handle {
		file_server
	}
}
