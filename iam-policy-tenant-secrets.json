{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "TenantKeySecretsCrud",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:CreateSecret",
        "secretsmanager:PutSecretValue",
        "secretsmanager:GetSecretValue",
        "secretsmanager:DeleteSecret"
      ],
      "Resource": "arn:aws:secretsmanager:*:*:secret:litellm-gateway/tenants/*"
    },
    {
      "Sid": "TenantKeySecretsList",
      "Effect": "Allow",
      "Action": ["secretsmanager:ListSecrets"],
      "Resource": "*"
    }
  ]
}
